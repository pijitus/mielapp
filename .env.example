# ==========================================
# Copiar este archivo como .env en producción
# (NO subir .env a repositorios)
# ==========================================

# Servidor SMTP de Hostinger (confirmar en hPanel)
MAIL_HOST=smtp.hostinger.com

# Puerto SMTP (recomendado 587 con TLS; alternativa 465 con SSL)
MAIL_PORT=587

# Usuario SMTP (cuenta creada en Hostinger)
MAIL_USERNAME=contacto@tudominio.com

# Password SMTP de la casilla (Hostinger)
MAIL_PASSWORD=REEMPLAZAR_PASSWORD_REAL

# Seguridad SMTP: tls o ssl
MAIL_ENCRYPTION=tls

# Remitente visible del correo
MAIL_FROM=contacto@tudominio.com
MAIL_FROM_NAME=MielApp Web

# Destinatario interno de notificaciones (ventas/comercial)
MAIL_TO=ventas@tudominio.com
